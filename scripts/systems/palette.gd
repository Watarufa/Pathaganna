## Akses terpusat ke palet material .tres (resources/materials/).
## Semua mesh mengambil material dari sini — material di-share antar mesh (performa).
class_name Palette
extends RefCounted

const STONE := preload("res://resources/materials/stone_dark.tres")
const CLOTH := preload("res://resources/materials/cloth_dark.tres")
const METAL := preload("res://resources/materials/metal_old.tres")
const CABLE := preload("res://resources/materials/cable_black.tres")
const SKIN := preload("res://resources/materials/skin_pale.tres")
const NEON_PURPLE := preload("res://resources/materials/neon_purple.tres")
const NEON_RED := preload("res://resources/materials/neon_red.tres")
const CRT_SCREEN := preload("res://resources/materials/crt_screen.tres")
const TELEGRAPH_WHITE := preload("res://resources/materials/telegraph_white.tres")
const TELEGRAPH_RED := preload("res://resources/materials/telegraph_red.tres")
const FLASH_OVERLAY := preload("res://resources/materials/flash_overlay.tres")
